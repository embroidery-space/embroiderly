        display: none;
      }
    </style>
    <div class="flex flex-col h-full p-1 select-none touch-none w-3" data-orientation="vertical" data-scrollbarimpl data-slot="scrollbar" data-state="visible">
      <div class="bg-inverted/75 relative rounded-full" data-slot="thumb" data-state="visible"></div>
    </div>
  </div>
</div>
`;

