exports[`ScrollArea > renders correctly with class 1`] = `
<div>
  <div class="h-64 overflow-hidden relative" data-slot="root" dir="ltr">
    <div class="size-full" data-reka-scroll-area-viewport data-slot="viewport" tabindex="0"></div>
    <style>
      /* Hide scrollbars cross-browser and enable momentum scroll for touch devices */
      [data-reka-scroll-area-viewport] {
        scrollbar-width: none;
        -ms-overflow-style: none;
