{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm check-types:*)",
      "Bash(pnpm fmt:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm -F:*)",
      "Bash(pnpm --filter:*)",
      "Bash(pnpm -r:*)",
      "Bash(pnpm --recursive:*)",
      "Bash(cargo check:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo +nightly fmt:*)",
      "Bash(cargo nextest:*)",
      "Bash(just check:*)",
      "Bash(just fmt:*)",
      "Bash(just lint:*)",
      "Bash(just test:*)",
      "Bash(just all:*)"
    ],
    "deny": [
      "Bash(cargo fmt)",
      "Bash(cargo fmt:*)",
      "Bash(cargo test:*)",
      "Read(**/node_modules/**)",
      "Read(**/target/**)",
      "Read(**/dist/**)",
      "Read(**/pkg/**)",
      "Read(**/gen/**)",
      "Read(**/cache/**)",
      "Read(**/logs/**)",
      "Read(**/.tmp/**)",
      "Read(**/.wrangler/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-locale-reads.sh"
          }
        ]
      }
    ]
  }
}
