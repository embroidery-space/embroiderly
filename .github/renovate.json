{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["replacements:all", "workarounds:all"],
  "ignorePaths": ["**/node_modules/**", "**/testdata/**", "**/tests/**"],
  "dependencyDashboard": true,
  "minimumReleaseAge": "3 days",
  "semanticCommitType": "chore",
  "packageRules": [
    {
      "extends": ["schedule:monthly", "helpers:githubDigestChangelogs", "helpers:pinGitHubActionDigests"],
      "matchManagers": ["github-actions"]
    },
    {
      "groupName": "npm minor/patch",
      "groupSlug": "npm-minor-patch",
      "extends": ["schedule:weekly", "helpers:disableTypesNodeMajor"],
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "groupName": "cargo minor/patch",
      "groupSlug": "cargo-minor-patch",
      "extends": ["schedule:weekly"],
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["minor", "patch"]
    }
  ]
}
