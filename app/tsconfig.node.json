{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": ["vite-plugins/**/*.ts", "ui.config.ts", "vite.config.ts", "wdio.config.ts"],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "@wdio/globals/types", "@wdio/mocha-framework"],
    "paths": {
      "#build/ui": ["./node_modules/@nuxt/ui/.nuxt/ui"]
    }
  }
}
