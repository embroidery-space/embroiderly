### Translations for the stitch names.

stitch-full = Хрест

stitch-petite = Петіт
stitch-petite-tl = Лівий верхній петіт
stitch-petite-tr = Правий верхній петіт
stitch-petite-br = Правий нижній петіт
stitch-petite-bl = Лівий нижній петіт

stitch-half = Півхрест
stitch-half-forward = Прямий півхрест
stitch-half-backward = Зворотний півхрест

stitch-quarter = Чвертьхрест
stitch-quarter-tl = Лівий верхній чвертьхрест
stitch-quarter-tr = Правий верхній чвертьхрест
stitch-quarter-br = Правий нижній чвертьхрест
stitch-quarter-bl = Лівий нижній чвертьхрест

stitch-back = Зворотний стібок
stitch-straight = Прямий стібок

stitch-french-knot = Фр. вузелок
stitch-bead = Бісер
