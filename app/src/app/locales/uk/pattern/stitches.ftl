### Translations for the stitch names.

stitch-full = Хрест

stitch-petite = Петіт
stitch-petite-tl = Верхній лівий петіт
stitch-petite-tr = Верхній правий петіт
stitch-petite-br = Нижній правий петіт
stitch-petite-bl = Нижній лівий петіт

stitch-half = Півхрест
stitch-half-forward = Прямий півхрест
stitch-half-backward = Зворотний півхрест

stitch-quarter = Чвертьхрест
stitch-quarter-tl = Верхній лівий чвертьхрест
stitch-quarter-tr = Верхній правий чвертьхрест
stitch-quarter-br = Нижній правий чвертьхрест
stitch-quarter-bl = Нижній лівий чвертьхрест

stitch-back = Зворотний стібок
stitch-straight = Прямий стібок

stitch-french-knot = Фрузлик
stitch-bead = Бісер
