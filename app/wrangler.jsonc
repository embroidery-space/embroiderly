{
  "$schema": "./node_modules/wrangler/config-schema.json",

  "name": "embroiderly-app",
  "compatibility_date": "2026-05-06",

  "main": "./server/main.ts",

  "preview_urls": true,
  "assets": {
    "directory": "./dist/",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS",
  },
}
