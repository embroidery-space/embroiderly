{
  "name": "@embroiderly/app",
  "version": "0.7.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm wasm:build-dev && concurrently -k -n \"VITE,RUST\" \"vite\" \"pnpm wasm:watch-dev\"",
    "build": "pnpm check-types && pnpm build-only",
    "build-only": "pnpm wasm:build && vite build",
    "wasm:build": "wasm-pack build src-wasm --release --target web --out-dir pkg",
    "wasm:build-dev": "wasm-pack build src-wasm --dev --target web --out-dir pkg",
    "wasm:watch-dev": "cargo watch --postpone --watch-when-idle --workdir src-wasm --shell \"wasm-pack build . --dev --target web --out-dir pkg\"",
    "check-types": "vue-tsc -b",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:components": "vitest run --project components",
    "test:e2e": "wdio run wdio.config.ts"
  },
  "dependencies": {
    "@embroiderly/ui": "workspace:",
    "@fluent/bundle": "catalog:",
    "@stdlib/math-base-special-roundn": "catalog:",
    "@tanstack/vue-hotkeys": "catalog:",
    "@tauri-apps/api": "catalog:",
    "@tauri-apps/plugin-fs": "catalog:",
    "@tauri-apps/plugin-opener": "catalog:",
    "@tauri-apps/plugin-process": "catalog:",
    "@tauri-apps/plugin-updater": "catalog:",
    "@vueuse/components": "catalog:",
    "@vueuse/core": "catalog:",
    "@vueuse/integrations": "catalog:",
    "@zorsh/zorsh": "catalog:",
    "bowser": "catalog:",
    "dequal": "catalog:",
    "eventemitter3": "catalog:",
    "fluent-vue": "catalog:",
    "fuse.js": "catalog:",
    "pinia": "catalog:",
    "pinia-plugin-persistedstate": "catalog:",
    "pixi.js": "catalog:",
    "reka-ui": "catalog:",
    "show-open-file-picker": "catalog:",
    "sortablejs": "catalog:",
    "stacktracey": "catalog:",
    "uuid": "catalog:",
    "vue": "catalog:"
  },
  "devDependencies": {
    "@iconify-json/material-symbols": "catalog:",
    "@iconify-json/mdi": "catalog:",
    "@pinia/testing": "catalog:",
    "@pixi/devtools": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tsconfig/node24": "catalog:",
    "@tsconfig/strictest": "catalog:",
    "@types/mocha": "catalog:",
    "@types/node": "catalog:",
