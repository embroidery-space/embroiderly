{
  "extends": ["@tsconfig/node24/tsconfig.json", "@tsconfig/strictest/tsconfig.json"],
  "include": ["wdio.shared.conf.ts", "wdio.desktop.conf.ts", "wdio.web.conf.ts", "tests/e2e/**/*.ts"],
  "exclude": ["tests/components/"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.wdio.tsbuildinfo",

    "noEmit": true,

    // Since TypeScript 6.0, the default lib is ES2025, but WebdriverIO doesn't support it yet.
    // Remove "lib" once it does.
    "lib": ["ES2024"],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "exactOptionalPropertyTypes": false,
    "noPropertyAccessFromIndexSignature": false,
    "strictPropertyInitialization": false,
    "noUncheckedIndexedAccess": false,

    "types": ["node", "mocha", "@wdio/globals/types", "@wdio/mocha-framework"]
  }
}
