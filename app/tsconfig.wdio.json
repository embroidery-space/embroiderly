{
  "extends": ["@tsconfig/node24/tsconfig.json", "@tsconfig/strictest/tsconfig.json"],
  "include": ["wdio.config.ts", "tests/e2e/**/*.ts"],
  "exclude": ["tests/components/"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.wdio.tsbuildinfo",

    "baseUrl": ".",

    "noEmit": true,

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "exactOptionalPropertyTypes": false,
    "noPropertyAccessFromIndexSignature": false,
    "strictPropertyInitialization": false,
    "noUncheckedIndexedAccess": false,

    "types": ["node", "mocha", "@wdio/globals/types", "@wdio/mocha-framework"]
  }
}
