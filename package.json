{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "tauri": "tauri",
    "dev": "pnpm --filter @embroiderly/app dev",
    "build": "pnpm --filter @embroiderly/app build",
    "fmt": "prettier --check .",
    "fmt:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tauri-apps/cli": "2.8.4",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.6.0",
    "eslint": "9.36.0",
    "eslint-plugin-better-tailwindcss": "3.7.9",
    "eslint-plugin-vue": "10.5.0",
    "eslint-plugin-yml": "1.18.0",
    "globals": "16.4.0",
    "prettier": "3.6.2",
    "tailwindcss": "4.1.13",
    "yaml-eslint-parser": "1.3.0"
  }
}
