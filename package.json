{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "tauri": "tauri",
    "|----- APPLICATION -----|": "",
    "app:dev": "pnpm --filter @embroiderly/app dev",
    "app:build": "pnpm --filter @embroiderly/app build",
    "app:build-only": "pnpm --filter @embroiderly/app build-only",
    "|----- DOCUMENTATION ----|": "",
    "docs:dev": "pnpm --filter @embroiderly/docs dev",
    "docs:build": "pnpm --filter @embroiderly/docs build",
    "docs:preview": "pnpm --filter @embroiderly/docs preview",
    "|----- PRODUCTION -----|": "",
    "embroiderly:all": "pnpm embroiderly:help && pnpm embroiderly:sidecars",
    "embroiderly:help": "pnpm docs:build && cp docs/dist/embroiderly.*.pdf app/src-tauri/help/",
    "embroiderly:sidecars": "node scripts/build-sidecars.js",
    "|----- UTILS -----|": "",
    "check-types": "pnpm -r check-types",
    "fmt": "prettier --check .",
    "fmt:fix": "prettier --write .",
    "lint": "eslint && markdownlint-cli2",
    "lint:fix": "eslint --fix && markdownlint-cli2 --fix",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@tauri-apps/cli": "2.9.6",
    "@vitest/eslint-plugin": "1.6.6",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.6.0",
    "eslint": "9.39.2",
    "eslint-plugin-better-tailwindcss": "4.0.2",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-no-only-tests": "3.3.0",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-sonarjs": "3.0.6",
    "eslint-plugin-unicorn": "62.0.0",
    "eslint-plugin-vue": "10.7.0",
    "eslint-plugin-wdio": "9.23.0",
    "eslint-plugin-yml": "3.0.0",
    "globals": "17.3.0",
    "markdownlint-cli2": "0.20.0",
    "prettier": "3.8.1",
    "tailwindcss": "4.1.18"
  }
}
