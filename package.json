{
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "|----- TOOLS -----|": "",
    "tauri": "tauri",
    "|----- APPLICATION -----|": "",
    "app:dev": "pnpm -F @embroiderly/app dev",
    "app:prod": "pnpm -F @embroiderly/app prod",
    "app:build": "pnpm -r wasm:build && pnpm -F @embroiderly/app build",
    "|----- DOCUMENTATION ----|": "",
    "docs:dev": "pnpm -F @embroiderly/docs dev",
    "docs:build": "pnpm -F @embroiderly/docs build",
    "docs:preview": "pnpm -F @embroiderly/docs preview",
    "|----- UI Kit ----|": "",
    "ui:dev": "pnpm -F @embroiderly/ui dev",
    "ui:build": "pnpm -F @embroiderly/ui build",
    "ui:preview": "pnpm -F @embroiderly/ui preview",
    "|----- PRODUCTION -----|": "",
    "embroiderly:help": "pnpm docs:build && cp docs/.vitepress/dist/embroiderly.*.pdf app/src-tauri/help/",
    "|----- UTILS -----|": "",
    "check-types": "pnpm -r check-types",
    "fmt": "oxfmt --check",
    "fmt:fix": "oxfmt --write",
    "lint": "oxlint --format stylish --deny-warnings && eslint --concurrency auto --max-warnings 0 && markdownlint-cli2 \"**/*.md\"",
    "lint:fix": "oxlint --fix --format stylish --deny-warnings && eslint --fix --concurrency auto --max-warnings 0 && markdownlint-cli2 --fix \"**/*.md\"",
    "test": "pnpm -r --workspace-concurrency 1 test"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "catalog:",
    "@eslint/compat": "catalog:",
    "@intlify/eslint-plugin-vue-i18n": "catalog:",
    "@tauri-apps/cli": "catalog:",
    "@vitest/eslint-plugin": "catalog:",
    "@vue/eslint-config-prettier": "catalog:",
    "@vue/eslint-config-typescript": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-better-tailwindcss": "catalog:",
    "eslint-plugin-import-x": "catalog:",
    "eslint-plugin-no-only-tests": "catalog:",
    "eslint-plugin-oxlint": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "eslint-plugin-wdio": "catalog:",
    "eslint-plugin-yml": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "markdownlint-cli2": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tailwindcss": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.2.2"
}
