{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "tauri": "tauri",
    "|----- APPLICATION -----|": "",
    "app:dev": "pnpm --filter @embroiderly/app dev",
    "app:build": "pnpm --filter @embroiderly/app build",
    "app:build-only": "pnpm --filter @embroiderly/app build-only",
    "|----- DOCUMENTATION ----|": "",
    "docs:dev": "pnpm --filter @embroiderly/docs dev",
    "docs:build": "pnpm --filter @embroiderly/docs build",
    "docs:preview": "pnpm --filter @embroiderly/docs preview",
    "|----- PRODUCTION -----|": "",
    "embroiderly:all": "pnpm embroiderly:help && pnpm embroiderly:sidecars",
    "embroiderly:help": "pnpm docs:build && cp docs/dist/embroiderly.*.pdf app/src-tauri/help/",
    "embroiderly:sidecars": "node scripts/build-sidecars.js",
    "|----- UTILS -----|": "",
    "check-types": "pnpm -r check-types",
    "fmt": "prettier --check .",
    "fmt:fix": "prettier --write .",
    "lint": "eslint && markdownlint-cli2",
    "lint:fix": "eslint --fix && markdownlint-cli2 --fix",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@tauri-apps/cli": "catalog:",
    "@vitest/eslint-plugin": "catalog:",
    "@vue/eslint-config-prettier": "catalog:",
    "@vue/eslint-config-typescript": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-better-tailwindcss": "catalog:",
    "eslint-plugin-import-x": "catalog:",
    "eslint-plugin-no-only-tests": "catalog:",
    "eslint-plugin-promise": "catalog:",
    "eslint-plugin-sonarjs": "catalog:",
    "eslint-plugin-unicorn": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "eslint-plugin-wdio": "catalog:",
    "eslint-plugin-yml": "catalog:",
    "globals": "catalog:",
    "markdownlint-cli2": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:"
  }
}
